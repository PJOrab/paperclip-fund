# --- Supabase (Dashboard → Project Settings → API) ---
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role-Key (serverseitig, umgeht RLS). NICHT der anon-Key, NICHT committen!
SUPABASE_SERVICE_KEY=

# --- Wiederverwendung der bestehenden Adapter ---
# Pfad zum macro-agent (default: ~/macro-agent). Dessen .env liefert die
# API-Keys (NEWSAPI_KEY, FRED_API_KEY, X-Cookies) für die Adapter.
MACRO_AGENT_DIR=/root/macro-agent

# --- Paperclip Coverage-QC ticketing (coverage_qc.py --open-tickets) ---
# Required for the post-briefing coverage-gap check to file issues automatically.
# PAPERCLIP_API_KEY: short-lived JWT injected by Paperclip at runtime (set by operator
#   in the n8n SSH env, or in this file for manual runs).
PAPERCLIP_API_KEY=
# Non-sensitive defaults — override only if running against a different instance.
PAPERCLIP_API_BASE=https://paperclip.hedgingalpha.com
PAPERCLIP_COMPANY_ID=f386ec58-21f8-4273-81df-1a187c82dc54
PAPERCLIP_DE_AGENT_ID=78b79ccb-7011-4753-b282-584d6136bfb6
