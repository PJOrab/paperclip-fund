# --- Supabase (Dashboard → Project Settings → API) ---
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role-Key (serverseitig, umgeht RLS). NICHT der anon-Key, NICHT committen!
SUPABASE_SERVICE_KEY=

# --- Wiederverwendung der bestehenden Adapter ---
# Pfad zum macro-agent (default: ~/macro-agent). Dessen .env liefert die
# API-Keys (NEWSAPI_KEY, FRED_API_KEY, X-Cookies) für die Adapter.
MACRO_AGENT_DIR=/root/macro-agent
